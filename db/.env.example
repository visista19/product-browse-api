# Postgres connection string used by the seed script.
# Supabase: Project Settings -> Database -> Connection string -> URI (Session pooler).
# Make sure it ends with ?sslmode=require
DATABASE_URL=postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-xx.pooler.supabase.com:5432/postgres?sslmode=require

# Optional: number of rows to generate (default 200000)
# SEED_COUNT=200000
